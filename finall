import java.util.*;

public class BarangayCugmanSystem {
    static Scanner sc = new Scanner(System.in);
    
    static ArrayList<String> names = new ArrayList<>();
    static ArrayList<String> ages = new ArrayList<>();
    static ArrayList<String> genders = new ArrayList<>();
    static ArrayList<String> birthMonths = new ArrayList<>();
    static ArrayList<String> civilStatuses = new ArrayList<>();
    static ArrayList<String> addresses = new ArrayList<>();
    static ArrayList<String> contacts = new ArrayList<>();
    static ArrayList<String> docs = new ArrayList<>();
    static ArrayList<String> status = new ArrayList<>();
    
    public static void main(String[] args) {
        while (true) {
            System.out.println("\n=== BARANGAY SYSTEM ===");
            System.out.println("1. Admin Login");
            System.out.println("2. Resident");
            System.out.println("3. Exit Program");
            System.out.print("Choose: ");
            
            int choice = readInt();
            
            if (choice == 3) {
                System.out.println("System Closed");
                break;
            }
            
            if (choice == 1) {
                adminMenu();
            } else if (choice == 2) {
                residentMenu();
            }
        }
    }
    
    static void adminMenu() {
        System.out.print("Username: ");
        String user = sc.nextLine();
        System.out.print("Password: ");
        String pass = sc.nextLine();
        
        if (user.equals("Admin") && pass.equals("1234")) {
            adminWork();
        } else {
            System.out.println("Invalid Login, Try Again!");
        }
    }
    
    static void adminWork() {
        System.out.println("Logged in as ADMIN!");
        
        while (true) {
            System.out.println("\nADMIN MENU:");
            System.out.println("1. View all requests");
            System.out.println("2. Update status");
            System.out.println("3. Logout");
            System.out.print("Choose: ");
            
            int choice = readInt();
            
            if (choice == 1) showAll();
            else if (choice == 2) updateStatus();
            else if (choice == 3) return;
        }
    }
    
    static void residentMenu() {
        System.out.println("=== RESIDENT REGISTRATION ===");
        
        // NAME
        String fullName;
        while (true) {
            System.out.print("Full Name: ");
            fullName = sc.nextLine();
            if (!fullName.trim().isEmpty()) break;
            else System.out.println("Invalid! Name cannot be empty.");
        }

        // AGE
        String ageInput;
        while (true) {
            System.out.print("Age: ");
            ageInput = sc.nextLine();
            if (ageInput.matches("\\d+")) break;
            else System.out.println("Invalid! Age must be a number.");
        }

        // GENDER
        String genderInput;
        while (true) {
            System.out.print("Gender (Male/Female): ");
            genderInput = sc.nextLine();
            if (genderInput.equalsIgnoreCase("Male") || genderInput.equalsIgnoreCase("Female")) {
                break;
            } else {
                System.out.println("Invalid! Enter Male or Female only.");
            }
        }

        // BIRTH MONTH
        String birthMonthInput;
        while (true) {
            System.out.print("Birth Month: ");
            birthMonthInput = sc.nextLine();
            if (!birthMonthInput.trim().isEmpty()) break;
            else System.out.println("Invalid! Cannot be empty.");
        }

        // CIVIL STATUS
        String civilStatusInput;
        while (true) {
            System.out.print("Civil Status (Single/Married/Widow): ");
            civilStatusInput = sc.nextLine();
            if (!civilStatusInput.trim().isEmpty()) break;
            else System.out.println("Invalid! Cannot be empty.");
        }

        // ADDRESS
        String addressInput;
        while (true) {
            System.out.print("Address: ");
            addressInput = sc.nextLine();
            if (!addressInput.trim().isEmpty()) break;
            else System.out.println("Invalid! Cannot be empty.");
        }

        // CONTACT NUMBER
        String contactInput;
        while (true) {
            System.out.print("Contact Number (09XXXXXXXXX): ");
            contactInput = sc.nextLine();
            if (contactInput.matches("^09\\d{9}$")) {
                break;
            } else {
                System.out.println("Invalid! Must be 11 digits and start with 09.");
            }
        }
    
        System.out.println("\n=== RESIDENT PROFILE ===");
        System.out.println("│ Name: " + fullName);
        System.out.println("│ Age: " + ageInput);
        System.out.println("│ Gender: " + genderInput);
        System.out.println("│ Birth Month: " + birthMonthInput);
        System.out.println("│ Civil Status: " + civilStatusInput);
        System.out.println("│ Address: " + addressInput);
        System.out.println("│ Contact: " + contactInput);
        System.out.println("└───────────────");
        System.out.println("Hi " + fullName + "! Welcome!");
        
        names.add(fullName);
        ages.add(ageInput);
        genders.add(genderInput);
        birthMonths.add(birthMonthInput);
        civilStatuses.add(civilStatusInput);
        addresses.add(addressInput);
        contacts.add(contactInput);
        
        while (true) {
            System.out.println("\nRESIDENT MENU:");
            System.out.println("1. Request document");
            System.out.println("2. My requests");
            System.out.println("3. Exit");
            System.out.print("Choose: ");
            
            int choice = readInt();
            
            if (choice == 1) requestDoc(fullName);
            else if (choice == 2) showMyRequests(fullName);
            else if (choice == 3) return;
        }
    }
    
    static void requestDoc(String name) {
        System.out.println("\n=== REQUEST DOCUMENT ===");
        System.out.println("1. Barangay Clearance");
        System.out.println("2. Barangay Permit");
        System.out.println("3. Certificate of Residency");
        System.out.println("4. Certificate of Indigency");
        System.out.print("Choose: ");
        
        int choice = readInt();
        String doc;
        
        if (choice == 1) doc = "Barangay Clearance";
        else if (choice == 2) doc = "Barangay Permit";
        else if (choice == 3) doc = "Certificate of Residency";
        else if (choice == 4) doc = "Certificate of Indigency";
        else {
            System.out.println("Invalid choice!");
            return;
        }
        
        docs.add(doc);
        status.add("Pending");
        
        System.out.println("✓ " + doc + " request sent!");
    }
    
    static void showMyRequests(String name) {
        System.out.println("\n=== MY REQUESTS (" + name + ") ===");
        boolean hasRequest = false;
        
        for (int i = 0; i < docs.size(); i++) {
            if (names.size() > 0 && names.get(names.size()-1).equalsIgnoreCase(name)) {
                System.out.println((i+1) + ". " + name + " - " + docs.get(i) + " - " + status.get(i));
                hasRequest = true;
            }
        }
        if (!hasRequest) {
            System.out.println("No requests yet.");
        }
    }
    
    static void showAll() {
        if (docs.isEmpty()) {
            System.out.println("No requests.");
            return;
        }
        
        System.out.println("\n=== ALL REQUESTS ===");
        for (int i = 0; i < docs.size(); i++) {
            System.out.println((i+1) + ". " + names.get(names.size()-1) + " - " + docs.get(i) + " - " + status.get(i));
        }
        System.out.println("Press Enter to continue...");
        sc.nextLine();
    }
    
    static void updateStatus() {
        if (docs.isEmpty()) {
            System.out.println("No requests.");
            return;
        }
        
        showAll();
        System.out.print("Request number: ");
        int num = readInt() - 1;
        
        if (num < 0 || num >= docs.size()) {
            System.out.println("Wrong number!");
            return;
        }
        
        System.out.println("1. Approved  2. Rejected ");
        System.out.print("Choose: ");
        int choice = readInt();
        
        if (choice == 1) status.set(num, "Approved");
        else if (choice == 2) status.set(num, "Rejected");
        else {
            System.out.println("Wrong choice!");
            return;
        }
        
        System.out.println("Updated!");
    }
    
    static int readInt() {
        while (true) {
            try {
                return Integer.parseInt(sc.nextLine());
            } catch (Exception e) {
                System.out.print("Enter number only: ");
            }
        }
    }
}
